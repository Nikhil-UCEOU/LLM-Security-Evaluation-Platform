# Application
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
API_KEY=cortexflow-dev-key

# Database
DATABASE_URL=sqlite+aiosqlite:///./cortexflow.db

# LLM Providers (add keys for providers you want to use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
COHERE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Default LLM
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# Adaptive Attack Engine (uses LLM to generate attacks)
ADAPTIVE_ATTACK_PROVIDER=openai
ADAPTIVE_ATTACK_MODEL=gpt-4o-mini
